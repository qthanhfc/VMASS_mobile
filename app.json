{
  "expo": {
    "name": "VMASS",
    "slug": "vmass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#008ecc"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "VMASS cần truy cập camera để quét mã vạch và QR code."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "VMASS cần truy cập thư viện ảnh để tìm sản phẩm bằng hình ảnh."
        }
      ]
    ]
  }
}
