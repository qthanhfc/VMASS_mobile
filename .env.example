EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_VMASS_API_URL=http://localhost:5000
EXPO_PUBLIC_VMASS_STORE_DOMAIN=vmass.vn

# Backend SMTP settings for feature feedback emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="VMASS <no-reply@example.com>"
FEEDBACK_TO_EMAIL=support@vmass.vn
FEEDBACK_SAVE_TIMEOUT_MS=2500
